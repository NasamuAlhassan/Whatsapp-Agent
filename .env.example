# ── Telegram ────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── User ────────────────────────────────────────────────────────────────────────
USER_NAME=YourName
USER_BIO=Computer Science student at UG Legon, Ghana
USER_PHONE=+233xxxxxxxxx

# ── Scheduling ──────────────────────────────────────────────────────────────────
DIGEST_INTERVAL_MINUTES=15
